{
    "env": {
        "node": true,
        "es2021": true,
        "jest": true
    },
    "extends": ["eslint:recommended"],
    "rules": {
        "no-unused-vars": "off",
        "no-console": "off",
        "no-empty": "warn",
        "no-constant-condition": "warn",
        "no-unreachable": "off"
    }
}